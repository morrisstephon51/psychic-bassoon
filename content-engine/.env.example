# Server
PORT=3001
NODE_ENV=development

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Brand Configuration
BRAND_NAME="The Plug AI"
BRAND_HANDLE="theplugai"
BRAND_NICHE="AI education for underserved communities"
BRAND_VOICE="Authentic, empowering, no-jargon, community-first"
BRAND_HASHTAGS="#AIForEveryone #ThePlugAI #AIEducation #BlackTech #TechForUs"

# Social Platforms (add tokens after OAuth)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

# Scheduling (cron syntax)
DAILY_SCHEDULE="0 9 * * *"
CONTENT_WINDOW_DAYS=7

# Video
FFMPEG_PATH=/usr/bin/ffmpeg
TEMP_DIR=/tmp/content-engine
ASSETS_DIR=./assets

# Database
DB_PATH=./data/content-engine.db
